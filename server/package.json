{
  "name": "zenvix-website",
  "version": "1.0.0",
  "private": true,

  "scripts": {
    "dev": "concurrently \"npm run server\" \"npm run client\"",

    "server": "cd server && nodemon index.js",

    "client": "cd client && npm run dev",

    "build": "cd client && npm install && npm run build",

    "start": "cd server && npm install && node index.js"
  },

  "dependencies": {
    "concurrently": "^8.2.2",
    "nodemon": "^3.1.0"
  }
}
